<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wk.pfmis.controllers.PeopleController" styleClass="panel">
    <Label text="People" styleClass="section-heading"/>
    <GridPane hgap="10" vgap="10">
        <Label text="Full Name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="fullNameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Phone" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <TextField fx:id="phoneField" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
        <Label text="Relationship" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="relationshipField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Notes" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <TextArea fx:id="notesArea" prefRowCount="2" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
    </GridPane>
    <HBox spacing="8">
        <Button text="Add Person" onAction="#addPerson" styleClass="primary-button"/>
        <Button text="View Ledger" onAction="#viewLedger" styleClass="secondary-button"/>
        <Button text="Give Money" onAction="#giveMoney" styleClass="secondary-button"/>
        <Button text="Receive Money" onAction="#receiveMoney" styleClass="secondary-button"/>
        <Button text="Print Statement" onAction="#printStatement" styleClass="secondary-button"/>
        <Button text="Refresh" onAction="#refresh" styleClass="secondary-button"/>
    </HBox>
    <TableView fx:id="peopleTable" prefHeight="220">
        <columns>
            <TableColumn fx:id="nameColumn" text="Full Name" prefWidth="220"/>
            <TableColumn fx:id="phoneColumn" text="Phone" prefWidth="160"/>
            <TableColumn fx:id="relationshipColumn" text="Relationship" prefWidth="180"/>
        </columns>
    </TableView>
</VBox>
