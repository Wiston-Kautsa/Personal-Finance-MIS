<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wk.pfmis.controllers.ProjectsController">
    <HBox alignment="CENTER_LEFT" spacing="12">
        <VBox spacing="4" HBox.hgrow="ALWAYS">
            <Label text="Add Project" styleClass="accounts-title"/>
            <Label text="Create projects for tracking budgets and project-related spending" styleClass="form-note"/>
        </VBox>
    </HBox>

    <TitledPane text="Project Details" collapsible="true" expanded="true" maxWidth="Infinity" styleClass="section-pane">
        <VBox spacing="14">
            <GridPane hgap="24" vgap="12">
                <Label text="Project Name *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="projectNameField" promptText="e.g. House Construction" prefWidth="430" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                <Label text="Planned Budget *" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <TextField fx:id="plannedBudgetField" promptText="0.00" prefWidth="430" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Start Date" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <DatePicker fx:id="startDatePicker" prefWidth="430" GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                <Label text="End Date" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <DatePicker fx:id="endDatePicker" prefWidth="430" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Project Status" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <ComboBox fx:id="statusBox" prefWidth="430" GridPane.columnIndex="0" GridPane.rowIndex="5"/>

                <Label text="Description / Notes" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                <TextArea fx:id="descriptionArea" prefRowCount="4" prefWidth="430" GridPane.columnIndex="0" GridPane.rowIndex="7" GridPane.columnSpan="2"/>
            </GridPane>
            <HBox spacing="10">
                <Button text="Save Project" onAction="#addProject" styleClass="account-save-button"/>
                <Button text="Clear" onAction="#clearForm" styleClass="account-outline-button"/>
                <Button text="Refresh" onAction="#refresh" styleClass="account-outline-button"/>
            </HBox>
        </VBox>
    </TitledPane>

    <TitledPane text="Existing Projects" collapsible="true" expanded="true" maxWidth="Infinity" VBox.vgrow="ALWAYS" styleClass="section-pane">
        <VBox spacing="10">
            <HBox spacing="10">
                <Button text="View Details" onAction="#viewDetails" styleClass="account-outline-button"/>
                <Button text="Add Activity" onAction="#addActivity" styleClass="account-outline-button"/>
                <Button text="Change Status" onAction="#changeStatus" styleClass="account-outline-button"/>
                <Button text="Close Project" onAction="#closeProject" styleClass="account-outline-button"/>
            </HBox>
            <TableView fx:id="projectsTable" prefHeight="280" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Project" prefWidth="220"/>
                    <TableColumn fx:id="plannedColumn" text="Planned Budget" prefWidth="150"/>
                    <TableColumn fx:id="spentColumn" text="Spent" prefWidth="140"/>
                    <TableColumn fx:id="remainingColumn" text="Remaining" prefWidth="150"/>
                    <TableColumn fx:id="startDateColumn" text="Start Date" prefWidth="120"/>
                    <TableColumn fx:id="endDateColumn" text="End Date" prefWidth="120"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>
    </TitledPane>

    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>
</VBox>
