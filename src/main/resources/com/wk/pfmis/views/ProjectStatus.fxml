<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wk.pfmis.controllers.ProjectStatusController">
    <HBox spacing="14">
        <VBox styleClass="metric-card" HBox.hgrow="ALWAYS">
            <Label text="Selected Project" styleClass="metric-title"/>
            <Label fx:id="selectedProjectLabel" text="No Project Selected" styleClass="overview-value"/>
        </VBox>
        <VBox styleClass="metric-card" HBox.hgrow="ALWAYS">
            <Label text="Current Status" styleClass="metric-title"/>
            <Label fx:id="currentStatusLabel" text="-" styleClass="metric-value"/>
        </VBox>
    </HBox>

    <TitledPane text="Change Project Status" collapsible="true" expanded="true" maxWidth="Infinity" styleClass="section-pane">
        <VBox spacing="14">
            <GridPane hgap="24" vgap="12">
                <Label text="Project *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <ComboBox fx:id="projectBox" prefWidth="430" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                <Label text="Project Status *" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <ComboBox fx:id="statusBox" prefWidth="430" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
            </GridPane>
            <HBox spacing="10">
                <Button text="Save Status" onAction="#saveStatus" styleClass="account-save-button"/>
                <Button text="Refresh" onAction="#refresh" styleClass="account-outline-button"/>
            </HBox>
        </VBox>
    </TitledPane>

    <TitledPane text="Projects" collapsible="true" expanded="true" maxWidth="Infinity" VBox.vgrow="ALWAYS" styleClass="section-pane">
        <TableView fx:id="projectsTable" prefHeight="300" VBox.vgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="nameColumn" text="Project" prefWidth="220"/>
                <TableColumn fx:id="plannedColumn" text="Planned Budget" prefWidth="150"/>
                <TableColumn fx:id="spentColumn" text="Spent" prefWidth="140"/>
                <TableColumn fx:id="remainingColumn" text="Remaining" prefWidth="150"/>
                <TableColumn fx:id="startDateColumn" text="Start Date" prefWidth="120"/>
                <TableColumn fx:id="endDateColumn" text="End Date" prefWidth="120"/>
                <TableColumn fx:id="statusColumn" text="Status" prefWidth="120"/>
            </columns>
        </TableView>
    </TitledPane>

    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>
</VBox>
