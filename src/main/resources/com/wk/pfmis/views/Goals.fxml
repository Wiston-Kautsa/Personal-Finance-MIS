<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wk.pfmis.controllers.GoalsController" styleClass="panel">
    <Label text="Financial Goals" styleClass="section-heading"/>
    <GridPane hgap="10" vgap="10">
        <Label text="Goal Name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="goalNameField" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Target Amount" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <TextField fx:id="targetAmountField" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
        <Label text="Current Amount" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
        <TextField fx:id="currentAmountField" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
        <Label text="Monthly Contribution" GridPane.columnIndex="2" GridPane.rowIndex="1"/>
        <TextField fx:id="monthlyContributionField" GridPane.columnIndex="3" GridPane.rowIndex="1"/>
        <Label text="Target Date" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
        <DatePicker fx:id="targetDatePicker" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
    </GridPane>
    <HBox spacing="8">
        <Button text="Add Goal" onAction="#addGoal" styleClass="primary-button"/>
        <Button text="Refresh" onAction="#refresh" styleClass="secondary-button"/>
    </HBox>
    <TableView fx:id="goalsTable" prefHeight="240">
        <columns>
            <TableColumn fx:id="nameColumn" text="Goal" prefWidth="180"/>
            <TableColumn fx:id="targetColumn" text="Target" prefWidth="110"/>
            <TableColumn fx:id="currentColumn" text="Current" prefWidth="110"/>
            <TableColumn fx:id="remainingColumn" text="Remaining" prefWidth="110"/>
            <TableColumn fx:id="monthsColumn" text="Months Needed" prefWidth="120"/>
            <TableColumn fx:id="statusColumn" text="Status" prefWidth="100"/>
        </columns>
    </TableView>
</VBox>
