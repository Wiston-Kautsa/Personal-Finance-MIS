<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wk.pfmis.controllers.AccountsController" styleClass="accounts-page">
    <HBox spacing="10" styleClass="account-summary-strip" VBox.vgrow="NEVER">
        <VBox spacing="3" HBox.hgrow="ALWAYS" styleClass="account-summary-tile">
            <Label text="Total Accounts" styleClass="metric-title"/>
            <Label fx:id="totalAccountsLabel" text="0" styleClass="metric-value"/>
        </VBox>
        <VBox spacing="3" HBox.hgrow="ALWAYS" styleClass="account-summary-tile">
            <Label text="Active Accounts" styleClass="metric-title"/>
            <Label fx:id="activeAccountsOverviewLabel" text="0" styleClass="metric-value"/>
        </VBox>
        <VBox spacing="3" HBox.hgrow="ALWAYS" styleClass="account-summary-tile account-summary-wide">
            <Label text="Default Currency" styleClass="metric-title"/>
            <Label fx:id="defaultCurrencyLabel" text="MWK - Malawian Kwacha" wrapText="true" styleClass="overview-value"/>
        </VBox>
        <Label text="Balances are calculated from saved income, expenses, and transfers." wrapText="true" HBox.hgrow="ALWAYS" styleClass="account-info-box account-info-inline"/>
    </HBox>

    <TitledPane fx:id="accountFormPane" text="New Account" collapsible="true" expanded="true" maxWidth="Infinity" styleClass="section-pane" VBox.vgrow="NEVER">
        <VBox spacing="12" styleClass="account-form-panel">
            <GridPane hgap="16" vgap="10">
                <Label text="Account Name *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                <TextField fx:id="accountNameField" promptText="e.g. Main Checking Account" minHeight="34" prefHeight="34" maxHeight="34" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                <Label text="Bank / Provider" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                <TextField fx:id="bankProviderField" promptText="e.g. Standard Bank, Airtel Money, Cash" minHeight="34" prefHeight="34" maxHeight="34" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                <Label text="Account Type *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                <ComboBox fx:id="accountTypeBox" editable="true" promptText="Cash, bank, mobile money..." minHeight="34" prefHeight="34" maxHeight="34" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                <Label text="Account Number" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                <TextField fx:id="accountNumberField" promptText="Optional" minHeight="34" prefHeight="34" maxHeight="34" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                <Label text="Currency *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                <ComboBox fx:id="currencyBox" editable="true" minHeight="34" prefHeight="34" maxHeight="34" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="5"/>

                <Label text="Status *" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                <ComboBox fx:id="statusBox" minHeight="34" prefHeight="34" maxHeight="34" maxWidth="Infinity" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                <Label text="Notes" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                <TextArea fx:id="notesArea" promptText="Optional account notes" prefRowCount="2" minHeight="64" prefHeight="64" maxHeight="64" maxWidth="Infinity" GridPane.columnIndex="0" GridPane.rowIndex="7" GridPane.columnSpan="2"/>
            </GridPane>
            <HBox spacing="8" alignment="CENTER_RIGHT" styleClass="account-form-actions">
                <Button text="Clear" onAction="#clearForm" styleClass="account-outline-button"/>
                <Button fx:id="saveAccountButton" text="Save Account" onAction="#addAccount" styleClass="account-save-button"/>
            </HBox>
        </VBox>
    </TitledPane>

    <TitledPane text="Accounts List" collapsible="true" expanded="true" maxWidth="Infinity" styleClass="section-pane">
        <VBox spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="account-table-toolbar">
                <TextField fx:id="searchField" promptText="Search accounts by name, type, provider, currency, or status" prefWidth="460" maxWidth="560" minHeight="34" prefHeight="34" maxHeight="34"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Button text="View History" onAction="#viewHistory" minHeight="34" prefHeight="34" maxHeight="34" styleClass="account-outline-button"/>
            </HBox>
            <TableView fx:id="accountsTable" prefHeight="340" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Account Name" prefWidth="210"/>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="140"/>
                    <TableColumn fx:id="providerColumn" text="Provider" prefWidth="160"/>
                    <TableColumn fx:id="currencyColumn" text="Currency" prefWidth="90"/>
                    <TableColumn fx:id="balanceColumn" text="Current Balance" prefWidth="140"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>
    </TitledPane>
    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>
</VBox>
