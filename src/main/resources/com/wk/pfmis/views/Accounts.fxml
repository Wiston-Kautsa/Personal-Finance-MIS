<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.TitledPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="16" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wk.pfmis.controllers.AccountsController">
    <TitledPane fx:id="accountFormPane" text="Add Account" collapsible="true" expanded="true" maxWidth="Infinity" styleClass="section-pane">
        <HBox spacing="16">
            <VBox spacing="14" HBox.hgrow="ALWAYS" styleClass="account-card account-card-flat">
                <GridPane hgap="22" vgap="10">
                    <Label text="Account Name *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="accountNameField" promptText="e.g. Main Checking Account" prefWidth="360" GridPane.columnIndex="0" GridPane.rowIndex="1"/>

                    <Label text="Bank / Provider Name *" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    <TextField fx:id="bankProviderField" promptText="e.g. Standard Bank" prefWidth="360" GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                    <Label text="Account Type *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <ComboBox fx:id="accountTypeBox" editable="true" promptText="Select account type" prefWidth="360" GridPane.columnIndex="0" GridPane.rowIndex="3"/>

                    <Label text="Account Number (Optional)" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="2"/>
                    <TextField fx:id="accountNumberField" promptText="e.g. 1234567890" prefWidth="360" GridPane.columnIndex="1" GridPane.rowIndex="3"/>

                    <Label text="Currency *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="4"/>
                    <ComboBox fx:id="currencyBox" editable="true" prefWidth="360" GridPane.columnIndex="0" GridPane.rowIndex="5"/>

                    <Label text="Notes (Optional)" styleClass="field-label" GridPane.columnIndex="1" GridPane.rowIndex="4"/>
                    <TextArea fx:id="notesArea" promptText="Add any notes about this account..." prefRowCount="2" prefWidth="360" GridPane.columnIndex="1" GridPane.rowIndex="5"/>

                    <Label text="Status *" styleClass="field-label" GridPane.columnIndex="0" GridPane.rowIndex="6"/>
                    <ComboBox fx:id="statusBox" prefWidth="360" GridPane.columnIndex="0" GridPane.rowIndex="7"/>
                </GridPane>
                <HBox spacing="10">
                    <Button fx:id="saveAccountButton" text="Save Account" onAction="#addAccount" styleClass="account-save-button"/>
                    <Button text="Reset" onAction="#clearForm" styleClass="account-outline-button"/>
                    <Button text="Cancel" onAction="#clearForm" styleClass="account-outline-button"/>
                </HBox>
            </VBox>

            <VBox spacing="16" prefWidth="330" styleClass="account-card account-card-flat">
                <Label text="Account Overview" styleClass="account-card-title"/>
                <VBox spacing="16">
                    <VBox spacing="4" styleClass="account-overview-row">
                        <Label text="Total Accounts" styleClass="metric-title"/>
                        <Label fx:id="totalAccountsLabel" text="0" styleClass="metric-value"/>
                    </VBox>
                    <VBox spacing="4" styleClass="account-overview-row">
                        <Label text="Active Accounts" styleClass="metric-title"/>
                        <Label fx:id="activeAccountsOverviewLabel" text="0" styleClass="metric-value"/>
                    </VBox>
                    <VBox spacing="4" styleClass="account-overview-row">
                        <Label text="Default Currency" styleClass="metric-title"/>
                        <Label fx:id="defaultCurrencyLabel" text="MWK - Malawian Kwacha" wrapText="true" styleClass="overview-value"/>
                    </VBox>
                </VBox>
                <Label text="Current balance is calculated from transactions." wrapText="true" styleClass="account-info-box"/>
            </VBox>
        </HBox>
    </TitledPane>

    <TitledPane text="Existing Accounts" collapsible="true" expanded="true" maxWidth="Infinity" styleClass="section-pane">
        <VBox spacing="10">
            <HBox alignment="CENTER_LEFT" spacing="12" styleClass="account-table-header">
                <TextField fx:id="searchField" promptText="Search Accounts..." prefWidth="260"/>
                <Button text="View History" onAction="#viewHistory" styleClass="account-outline-button"/>
                <Button text="Delete Selected" onAction="#deleteAccount" styleClass="account-danger-button"/>
                <Button text="Refresh" onAction="#refresh" styleClass="account-outline-button"/>
            </HBox>
            <TableView fx:id="accountsTable" prefHeight="250">
                <columns>
                    <TableColumn fx:id="nameColumn" text="Account Name" prefWidth="210"/>
                    <TableColumn fx:id="typeColumn" text="Type" prefWidth="140"/>
                    <TableColumn fx:id="providerColumn" text="Bank / Provider" prefWidth="160"/>
                    <TableColumn fx:id="currencyColumn" text="Currency" prefWidth="90"/>
                    <TableColumn fx:id="balanceColumn" text="Current Balance" prefWidth="140"/>
                    <TableColumn fx:id="statusColumn" text="Status" prefWidth="110"/>
                </columns>
            </TableView>
        </VBox>
    </TitledPane>
    <padding>
        <Insets top="0" right="0" bottom="0" left="0"/>
    </padding>
</VBox>
