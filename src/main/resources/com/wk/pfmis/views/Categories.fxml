<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="12" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.wk.pfmis.controllers.CategoriesController" styleClass="panel">
    <Label text="Categories" styleClass="section-heading"/>
    <GridPane hgap="10" vgap="10">
        <Label text="Category Name" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
        <TextField fx:id="categoryNameField" promptText="Transport" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
        <Label text="Type" GridPane.columnIndex="2" GridPane.rowIndex="0"/>
        <ComboBox fx:id="categoryTypeBox" prefWidth="160" GridPane.columnIndex="3" GridPane.rowIndex="0"/>
    </GridPane>
    <HBox spacing="8">
        <Button text="Add Category" onAction="#addCategory" styleClass="primary-button"/>
        <Button text="Refresh" onAction="#refresh" styleClass="secondary-button"/>
    </HBox>
    <TableView fx:id="categoriesTable" prefHeight="240">
        <columns>
            <TableColumn fx:id="nameColumn" text="Category" prefWidth="260"/>
            <TableColumn fx:id="typeColumn" text="Type" prefWidth="160"/>
        </columns>
    </TableView>
</VBox>
